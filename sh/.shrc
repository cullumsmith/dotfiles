case $(uname) in
  Linux) exec bash ;;
esac

reset=$(printf '\033[0m')
blue=$(printf '\033[34m')
green=$(printf '\033[32m')

PS1="\[${green}\]\u@\h\[${reset}\]:\[${blue}\]\W\[${green}\]\$\[${reset}\] "
unset reset blue green

export CLICOLOR=1
export PAGER=less
export LESS='-iMRSF -x2'
export EDITOR=vim
export LSCOLORS=DxfxgxgxcxxbxbaCacADAd

HISTSIZE=5000

alias ls='ls -FHh'
alias ll='ls -l'
alias la='ls -la'
alias ..='cd ..'
alias ...='cd ../..'
alias mkdir='mkdir -p'
alias df='df -h'
alias du='du -ch'
alias history='fc -l'

bind ^[[A ed-search-prev-history
bind ^[[B ed-search-next-history
bind "\\e[1;5C" em-next-word
bind "\\e[1;5D" ed-prev-word
